# ── Supabase (required) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_or_public_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PROJECT_REF=your-project-ref
# For `npm run db:migrate:columns` and `supabase gen types` (from `npx supabase login`)
# SUPABASE_ACCESS_TOKEN=
# Direct Postgres URL for `npm run migrate:local:ps1` (Dashboard → Settings → Database)
# SUPABASE_DB_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Public site URL (email links, M-Pesa callback, SEO)
PUBLIC_APP_URL=https://nyumba-search.kevinbuluma1.workers.dev
SITE_URL=https://nyumba-search.kevinbuluma1.workers.dev
VITE_SITE_URL=https://nyumba-search.kevinbuluma1.workers.dev

# ── Demo listings (optional) ────────────────────────────────────────
# Off by default in production. Set to 1 to show mock listings when DB is empty.
# NYUMBA_USE_MOCK_LISTINGS=0

# ── M-Pesa Daraja — Lipa na M-Pesa Online STK Push (optional) ─────
# Without these, payments auto-complete in demo mode.
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=  (sandbox default for shortcode 174379: see Safaricom Daraja Lipa Na M-Pesa Online docs)
# MPESA_CALLBACK_URL=https://your-domain.workers.dev/api/mpesa/callback

# ── SendGrid (optional — contact form + message email alerts) ─────
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=notifications@yourdomain.com
# OPS_NOTIFICATION_EMAIL=ops@yourdomain.com

# ── Google Maps (optional — map view; CSS fallback works without) ───
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_TRACKING_ID=

# ── Mapbox (optional — 3D terrain map; preferred when set) ──────────
# VITE_MAPBOX_TOKEN=

# ── NyumbaAI ─────────────────────────────────────────────────────────
# Production uses Cloudflare Workers AI (no key). For local dev or Gemini preference:
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# ── Caretaker sessions (optional — set in production) ───────────────
# CARETAKER_SESSION_SECRET=

# Cloudflare deploy: set secrets with `npx wrangler secret put NAME`
# Do not commit real keys to git.
