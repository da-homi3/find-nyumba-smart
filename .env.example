# Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_or_public_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_public_key

# Supabase service role key (server only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: project ref for supabase CLI commands
SUPABASE_PROJECT_REF=your-project-ref

# Wrangler (Cloudflare) or deploy secrets may be required for deployment
# e.g. WRANGLER_API_TOKEN, ACCOUNT_ID, etc.
