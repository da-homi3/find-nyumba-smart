# NyumbaSearch — environment variables
# Copy to .env and fill in values. Never commit .env with real secrets.

# ── Supabase (required) ─────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role  # Worker secret only — never expose to client

# ── Cloudflare (deploy) ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=7ff77105e5fd9fb5f560d381ec562ed8

# ── App URLs ────────────────────────────────────────────────────────
PUBLIC_APP_URL=https://nyumbasearch.com
SITE_URL=https://nyumbasearch.com
VITE_SITE_URL=https://nyumbasearch.com

# ── Email (SendGrid) ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=hello@nyumbasearch.co.ke
OPS_NOTIFICATION_EMAIL=ops@nyumbasearch.co.ke

# ── M-Pesa Daraja ───────────────────────────────────────────────────
MPESA_ENV=sandbox
MPESA_SHORTCODE=174379
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://nyumbasearch.com/api/mpesa/callback
# Optional HMAC verification for M-Pesa callbacks
MPESA_WEBHOOK_SECRET=

# ── Pesapal (card payments) ─────────────────────────────────────────
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=https://nyumbasearch.com/api/payments/callback/card
PESAPAL_NOTIFICATION_ID=
VITE_PESAPAL_CHECKOUT_ENABLED=true

# ── Maps ────────────────────────────────────────────────────────────
# Public Mapbox token — safe in VITE_ prefix
VITE_MAPBOX_TOKEN=pk.eyJ...
MAPBOX_PUBLIC_TOKEN=pk.eyJ...
# Optional Google Maps fallback
VITE_GOOGLE_MAPS_API_KEY=

# ── AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# NVIDIA NIM (NyumbaAI primary — rotates models on rate limits)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Cloudflare Workers AI binding "AI" is configured in wrangler — no key needed for Workers AI

# ── Cron & internal ─────────────────────────────────────────────────
CRON_SECRET=generate-a-random-string
CARETAKER_SESSION_SECRET=generate-32-byte-hex

# ── WhatsApp Business API (listing bot) ─────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=generate-a-random-string
WHATSAPP_PHONE_ID=
# Public display number for wa.me links (client-safe)
VITE_WHATSAPP_NUMBER=+254700000000

# ── Feature flags ───────────────────────────────────────────────────
NYUMBA_USE_MOCK_LISTINGS=0
ALLOW_DEMO_PAYMENTS=false
# Android FCM: token storage is always on; set true only when ready to send pushes
FCM_SEND_ENABLED=false

# Smoke / E2E test accounts (never commit real user passwords)
NYUMBA_SMOKE_TEST_PASSWORD=

# ── Client-only (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon-key

# ── Google sign-in (Supabase Auth) ──────────────────────────────────
# Enable Google provider in Supabase Dashboard → Authentication → Providers.
# Authorized redirect URLs must include:
#   https://nyumbasearch.com/auth/callback
#   http://localhost:3000/auth/callback   (dev)
# Google Cloud Console OAuth client → authorized redirect:
#   https://<project-ref>.supabase.co/auth/v1/callback
# No extra VITE_ Google OAuth client ID is required in the app — Supabase brokers it.
