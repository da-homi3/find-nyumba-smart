<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NyumbaSearch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/forest_green</item>
        <item name="colorSecondary">@color/mint</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.NyumbaSearch.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_cocoa</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">400</item>
        <item name="postSplashScreenTheme">@style/Theme.NyumbaSearch</item>
    </style>
</resources>
